{
  "name": "super-js-compiler",
  "version": "0.1.0",
  "description": "A type-safe JavaScript superset compiler",
  "main": "src/index.js",
  "scripts": {
    "test": "jest",
    "lint": "eslint src/**/*.js",
    "build": "babel src -d dist",
    "test:lexer": "jest src/lexer/lexer.test.js",
    "test:lexer:sample": "jest src/lexer/sample-sjs.test.js",
    "test:parser": "jest src/parser/parser.test.js",
    "test:parser:sample": "jest src/parser/sample-sjs.test.js",
    "test-all": "npm run test:lexer && npm run test:lexer:sample && npm run test:parser && npm run test:parser:sample"
  },
  "keywords": [
    "compiler",
    "javascript",
    "typescript",
    "type-safe"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "eslint": "^8.52.0",
    "jest": "^29.0.0"
  }
} 