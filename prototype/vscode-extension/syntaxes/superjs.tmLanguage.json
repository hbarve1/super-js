{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Super.js",
  "scopeName": "source.sjs",
  "patterns": [
    { "include": "#jsx" },
    { "include": "#expression" }
  ],
  "repository": {
    "expression": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#string" },
        { "include": "#template" },
        { "include": "#class" },
        { "include": "#type" },
        { "include": "#interface" },
        { "include": "#function" },
        { "include": "#keywords" },
        { "include": "#constant" },
        { "include": "#support" },
        { "include": "#variable" }
      ]
    },
    "jsx": {
      "patterns": [
        {
          "name": "meta.tag.jsx",
          "begin": "(<)([a-zA-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.jsx" }
          },
          "end": "(/?>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.end.jsx" }
          },
          "patterns": [
            { "include": "#jsx-attributes" },
            { "include": "#expression" }
          ]
        },
        {
          "name": "meta.tag.jsx",
          "begin": "(</)([a-zA-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx" },
            "2": { "name": "entity.name.tag.jsx" }
          },
          "end": "(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.end.jsx" }
          }
        }
      ]
    },
    "jsx-attributes": {
      "patterns": [
        {
          "match": "([a-zA-Z][a-zA-Z0-9]*)\\s*(=)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.jsx" },
            "2": { "name": "keyword.operator.assignment.jsx" }
          }
        },
        { "include": "#string" },
        { "include": "#expression" }
      ]
    },
    "type": {
      "patterns": [
        {
          "match": "\\b(type|interface)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.other.type.sjs" },
            "2": { "name": "entity.name.type.sjs" }
          }
        },
        {
          "match": ":\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\[])*)",
          "captures": {
            "1": { "name": "support.type.primitive.sjs" }
          }
        }
      ]
    },
    "interface": {
      "name": "meta.interface.sjs",
      "begin": "\\b(interface)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*",
      "beginCaptures": {
        "1": { "name": "keyword.other.interface.sjs" },
        "2": { "name": "entity.name.type.interface.sjs" }
      },
      "end": "(?<=\\})",
      "patterns": [
        { "include": "#type-members" }
      ]
    },
    "class": {
      "name": "meta.class.sjs",
      "begin": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "beginCaptures": {
        "1": { "name": "keyword.other.class.sjs" },
        "2": { "name": "entity.name.type.class.sjs" }
      },
      "end": "(?<=\\})",
      "patterns": [
        { "include": "#class-members" }
      ]
    },
    "function": {
      "name": "meta.function.sjs",
      "begin": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*",
      "beginCaptures": {
        "1": { "name": "keyword.other.function.sjs" },
        "2": { "name": "entity.name.function.sjs" }
      },
      "end": "(?<=\\})|(?=;)",
      "patterns": [
        { "include": "#function-parameters" },
        { "include": "#return-type" },
        { "include": "#expression" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sjs",
          "match": "\\b(if|else|while|for|do|switch|case|break|continue|return|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.operator.sjs",
          "match": "\\b(new|delete|typeof|instanceof|void|as|is)\\b"
        },
        {
          "name": "storage.type.sjs",
          "match": "\\b(let|const|var|function|class|interface|type|enum)\\b"
        },
        {
          "name": "storage.modifier.sjs",
          "match": "\\b(private|protected|public|static|readonly|abstract|async|await)\\b"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.language.sjs",
          "match": "\\b(true|false|null|undefined|NaN|Infinity)\\b"
        },
        {
          "name": "constant.numeric.sjs",
          "match": "\\b((0(x|X)[0-9a-fA-F]+)|(0(b|B)[01]+)|(0(o|O)[0-7]+)|([0-9]+(\\.[0-9]+)?))\\b"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.single.sjs",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.sjs", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.double.sjs",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.sjs", "match": "\\\\." }
          ]
        }
      ]
    },
    "template": {
      "name": "string.template.sjs",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "expression.embedded.sjs",
          "begin": "\\${",
          "end": "}",
          "patterns": [
            { "include": "#expression" }
          ]
        },
        {
          "name": "constant.character.escape.sjs",
          "match": "\\\\."
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sjs",
          "match": "//.*$"
        },
        {
          "name": "comment.block.sjs",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "support": {
      "patterns": [
        {
          "name": "support.class.sjs",
          "match": "\\b(Array|Boolean|Date|Error|Function|JSON|Math|Number|Object|RegExp|String|Promise|Map|Set|Symbol|TypedArray)\\b"
        },
        {
          "name": "support.type.primitive.sjs",
          "match": "\\b(string|number|boolean|null|undefined|void|never|any|unknown)\\b"
        }
      ]
    },
    "variable": {
      "patterns": [
        {
          "name": "variable.other.readwrite.sjs",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
} 