{
  "name": "superjs-vscode",
  "displayName": "Super.js Language Support",
  "description": "Language support for super.js - A strict, clean, and efficient superset of JavaScript",
  "version": "0.1.2",
  "publisher": "superjs",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters"
  ],
  "contributes": {
    "languages": [
      {
        "id": "superjs",
        "aliases": [
          "Super.js",
          "superjs",
          "sjs"
        ],
        "extensions": [
          ".sjs"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "superjs",
        "scopeName": "source.sjs",
        "path": "./syntaxes/superjs.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package -o publish/superjs-vscode.vsix",
    "publish": "npm run package && vsce publish",
    "version:major": "node scripts/version.js major",
    "version:minor": "node scripts/version.js minor",
    "version:patch": "node scripts/version.js patch",
    "release:major": "npm run version:major && npm run package",
    "release:minor": "npm run version:minor && npm run package",
    "release:patch": "npm run version:patch && npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.8.3"
  },
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/hbarve1/super-js.git"
  },
  "keywords": [
    "superjs",
    "syntax",
    "highlighting"
  ],
  "author": "Himank Barve",
  "license": "MIT"
}
