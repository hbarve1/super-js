{
  "name": "@superjs/compiler-types",
  "version": "0.1.0-alpha.0",
  "description": "Shared TypeScript type definitions for the SuperJS compiler (AST nodes, diagnostics, type system)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["superjs", "compiler", "types", "ast"],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
