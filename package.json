{
  "name": "super-js",
  "version": "0.1.0",
  "description": "A strict, clean, and efficient superset of JavaScript that enforces ECMA standards with built-in type safety",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "superjs": "./bin/superjs.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "javascript",
    "superset",
    "compiler",
    "typescript",
    "ecmascript",
    "formatter",
    "linter",
    "testing"
  ],
  "author": "super.js team",
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "commander": "^12.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.2"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.20.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
} 