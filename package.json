{
  "name": "superjs-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "prototype"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "release": "changeset publish",
    "check-grammar": "node scripts/check-grammar.mjs",
    "check-config": "node scripts/validate-config.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "ajv": "^8.20.0"
  }
}
