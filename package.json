{
  "name": "super-js",
  "version": "0.1.0",
  "description": "A strict, clean, and efficient superset of JavaScript that enforces ECMA standards with built-in type safety",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "superjs": "./bin/superjs.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "example:todo": "node dist/cli.js build --source examples/advanced/todo-list.sjs --outDir build",
    "example:watch": "node dist/cli.js build --source examples/advanced/todo-list.sjs --watch --outDir build",
    "examples": "npm run example:todo",
    "build:examples": "for file in examples/**/*.sjs; do node dist/cli.js build --source \"$file\" --outDir build; done",
    "start:dev": "ts-node src/cli.ts",
    "watch:dev": "ts-node-dev --respawn src/cli.ts",
    "compile": "ts-node src/cli.ts build --source",
    "compile:watch": "ts-node-dev --respawn src/cli.ts build --source",
    "compile:dir": "ts-node src/cli.ts build --dir",
    "compile:all": "ts-node src/cli.ts build --dir ./ --outDir build",
    "compile:examples": "ts-node src/cli.ts build --dir ./examples --outDir build",
    "compile:watch:dir": "ts-node-dev --respawn src/cli.ts build --dir",
    "run": "node",
    "run:example": "npm run compile -- examples/advanced/todo-list.sjs --outDir build && node build/examples/advanced/todo-list.js",
    "run:file": "node scripts/run-sjs.js",
    "run:dir": "node scripts/run-dir.js",
    "run:all": "node scripts/run-all.js",
    "run:examples": "node scripts/run-examples.js",
    "clean": "rm -rf dist build",
    "clean:build": "rm -rf build",
    "clean:dist": "rm -rf dist",
    "build:parallel": "node scripts/run-dir.js --parallel",
    "build:grouped": "node scripts/run-dir.js --group-by-type",
    "build:flat": "node scripts/run-dir.js --flatten",
    "build:custom": "node scripts/run-dir.js --custom-paths",
    "build:incremental": "node scripts/run-dir.js --incremental",
    "build:sourcemaps": "node scripts/run-dir.js --sourcemaps",
    "build:watch": "node scripts/run-dir.js --watch",
    "build:cache": "node scripts/run-dir.js --cache",
    "build:clean": "node scripts/run-dir.js --clean"
  },
  "keywords": [
    "javascript",
    "superset",
    "compiler",
    "typescript",
    "ecmascript",
    "formatter",
    "linter",
    "testing"
  ],
  "author": "super.js team",
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/generator": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "commander": "^12.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.2"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.20.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
