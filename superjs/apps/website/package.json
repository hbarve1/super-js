{
  "name": "@superjs/website",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "npx pagefind --site .next/server/app --output-path public/pagefind || true",
    "start": "next start",
    "doctor": "react-doctor --no-telemetry",
    "build:cf": "npx @cloudflare/next-on-pages",
    "preview:cf": "npm run build:cf && npx wrangler pages dev .vercel/output/static",
    "deploy:cf": "npm run build:cf && npx wrangler pages deploy .vercel/output/static --project-name superjs-website"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@shikijs/rehype": "^4.2.0",
    "@superjs/compiler": "workspace:*",
    "@superjs/diagnostics": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "geist": "^1.7.1",
    "js-yaml": "^4.2.0",
    "monaco-editor": "^0.55.1",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.7",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@next/eslint-plugin-next": "16.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "react-doctor": "^0.5.5",
    "tailwindcss": "^4",
    "typescript": "~6.0.3"
  }
}
