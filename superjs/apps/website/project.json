{
  "name": "@superjs/website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/website/src",
  "tags": ["tier:app", "scope:internal"],
  "targets": {
    "dev": {
      "command": "next dev",
      "options": { "cwd": "apps/website" }
    },
    "build": {
      "command": "next build",
      "options": { "cwd": "apps/website" },
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{projectRoot}/.next"]
    },
    "start": {
      "command": "next start",
      "options": { "cwd": "apps/website" }
    },
    "typecheck": {
      "command": "tsc --noEmit",
      "options": { "cwd": "apps/website" }
    },
    "lint": {
      "command": "eslint .",
      "options": { "cwd": "apps/website" }
    }
  }
}
